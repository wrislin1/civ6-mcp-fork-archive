# CivBench eval credentials
# Copy to evals/.env and fill in values

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# GCP Vertex AI (Gemini models)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Anthropic Vertex AI (Claude models via GCP)
CLOUD_ML_REGION=global
ANTHROPIC_VERTEX_PROJECT_ID=

# Cloud telemetry (Azure Blob Storage)
CIV_MCP_TELEMETRY_BUCKET=az://telemetry
AZURE_STORAGE_ACCOUNT_NAME=civbenchstorage
AZURE_STORAGE_ACCOUNT_KEY=
# Read-only SAS token for collaborator access (used by scripts/analyze.py and
# scripts/publish_hf_dataset.py). Either the bare query string ("sp=rl&...") or
# the full container URL (the publisher strips the URL prefix automatically).
AZURE_SAS_TOKEN=

# Hugging Face dataset publishing (scripts/publish_hf_dataset.py).
# Token must have write scope to the target dataset namespace.
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Alerts (ntfy push notifications on stalls/game-over)
CIV_MCP_ALERT_WEBHOOK=https://ntfy.sh/your-topic-here
